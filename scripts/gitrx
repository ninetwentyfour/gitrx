#!/bin/sh
# gitrx - GitX-style launcher for the gitrx Tauri app.
#
# Usage: gitrx [path]
#   path  Directory to open (defaults to "."). May be a repo root or any
#         subdirectory of one; the app discovers the enclosing working tree.
#
# This launches the app detached (freeing your terminal). If the app is already
# running, the single-instance plugin forwards this path to it — focusing the
# existing window for that repo, or opening a new one — and this process exits;
# no second Dock icon is spawned.
#
# Binary discovery order (first match wins):
#   1. $GITRX_APP            override: a .app bundle OR a direct binary path
#   2. /Applications/gitrx.app/Contents/MacOS/gitrx
#   3. ~/Applications/gitrx.app/Contents/MacOS/gitrx
#   4. /Applications/rust-gitx.app/Contents/MacOS/rust-gitx        (legacy)
#   5. ~/Applications/rust-gitx.app/Contents/MacOS/rust-gitx       (legacy)
#   6. <repo>/src-tauri/target/release/bundle/macos/gitrx.app/... (dev)
#      Only when this script still lives in the project's scripts/ dir.

set -eu

APP_NAME="gitrx"
# Previous bundle name; an existing install under the old name still launches.
LEGACY_APP_NAME="rust-gitx"

usage() {
	cat <<EOF
gitrx - open a git repository in the ${APP_NAME} app

Usage:
  gitrx [path]     Open PATH (default ".") in ${APP_NAME}, focusing an
                   existing window for that repo or opening a new one
  gitrx --help     Show this help

Environment:
  GITRX_APP        Override the app location. May point at either a .app
                   bundle or directly at an executable.

Examples:
  gitrx .              # open the current directory's repo
  gitrx ~/code/myrepo  # open a specific repo (shell expands ~)
EOF
}

die() {
	printf 'gitrx: %s\n' "$1" >&2
	exit 1
}

case "${1:-}" in
	-h | --help)
		usage
		exit 0
		;;
esac

# --- Resolve the target path to an absolute, real path -----------------------
target="${1:-.}"
[ -e "$target" ] || die "path does not exist: $target"
[ -d "$target" ] || die "not a directory: $target"
abs=$(cd "$target" 2>/dev/null && pwd -P) || die "cannot access directory: $target"

# --- Resolve this script's own directory (for the dev-build fallback) --------
# Follow a single level of symlink; installs COPY the script, so in practice
# this resolves to wherever the running copy lives.
script_src="$0"
if [ -L "$script_src" ]; then
	link=$(readlink "$script_src")
	case "$link" in
		/*) script_src="$link" ;;
		*) script_src=$(dirname "$script_src")/"$link" ;;
	esac
fi
script_dir=$(cd "$(dirname "$script_src")" 2>/dev/null && pwd -P) || script_dir=""

# --- Locate the app binary ---------------------------------------------------
bin=""

resolve_candidate() {
	# Accept a .app bundle, a MacOS dir, or a direct executable; echo the
	# runnable binary path if usable, else echo nothing. $2 is the binary/app
	# name expected inside a bundle (differs between the new and legacy bundles).
	c="$1"
	name="$2"
	if [ -d "$c" ]; then
		if [ -x "$c/Contents/MacOS/$name" ]; then
			printf '%s\n' "$c/Contents/MacOS/$name"
		elif [ -x "$c/$name" ]; then
			printf '%s\n' "$c/$name"
		fi
	elif [ -x "$c" ]; then
		printf '%s\n' "$c"
	fi
}

# 1. Explicit override. A bundle could carry either the new or legacy name.
if [ -n "${GITRX_APP:-}" ]; then
	bin=$(resolve_candidate "$GITRX_APP" "$APP_NAME")
	[ -n "$bin" ] || bin=$(resolve_candidate "$GITRX_APP" "$LEGACY_APP_NAME")
	[ -n "$bin" ] || die "GITRX_APP is set but no runnable binary found at: $GITRX_APP"
fi

# 2 & 3. Installed locations (new bundle name).
if [ -z "$bin" ]; then
	for base in "/Applications/${APP_NAME}.app" "$HOME/Applications/${APP_NAME}.app"; do
		bin=$(resolve_candidate "$base" "$APP_NAME")
		[ -n "$bin" ] && break
	done
fi

# 4 & 5. Legacy installed locations (old bundle name), so a pre-rename install
# still launches.
if [ -z "$bin" ]; then
	for base in "/Applications/${LEGACY_APP_NAME}.app" "$HOME/Applications/${LEGACY_APP_NAME}.app"; do
		bin=$(resolve_candidate "$base" "$LEGACY_APP_NAME")
		[ -n "$bin" ] && break
	done
fi

# 6. Dev build, only if this script still lives in <repo>/scripts.
if [ -z "$bin" ] && [ -n "$script_dir" ]; then
	repo_root=$(dirname "$script_dir")
	if [ -d "$repo_root/src-tauri" ]; then
		dev_app="$repo_root/src-tauri/target/release/bundle/macos/${APP_NAME}.app"
		bin=$(resolve_candidate "$dev_app" "$APP_NAME")
	fi
fi

if [ -z "$bin" ]; then
	die "could not find the ${APP_NAME} app.
  Build it with:   bun run tauri build
  or set GITRX_APP to the app bundle or binary path."
fi

# --- Launch detached ---------------------------------------------------------
# On a cold start this opens the app; if it is already running the single-
# instance plugin forwards "$abs" to the running app and this process exits.
nohup "$bin" "$abs" >/dev/null 2>&1 &
