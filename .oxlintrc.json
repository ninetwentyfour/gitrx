{
  "$schema": "https://raw.githubusercontent.com/oxc-project/oxc/main/npm/oxlint/configuration_schema.json",
  "plugins": ["react", "typescript", "unicorn", "oxc", "promise"],
  "env": {
    "browser": true,
    "es2024": true
  },
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "perf": "error",
    "pedantic": "error",
    // Zero-warnings policy: the style tier is "error" (never "warn"), so every
    // finding either gets fixed in code or an individually justified per-rule
    // "off" below. `bun run lint` also passes `--max-warnings 0`, so any future
    // warning-level finding fails the run.
    "style": "error"
  },
  "rules": {
    // --- Cherry-picked restriction rules (category itself stays off) ---
    // Stray `debugger` must never reach a commit/build.
    "no-debugger": "error",
    // Dynamic code execution is never legitimate in this app; ban it outright.
    "no-eval": "error",
    "no-implied-eval": "error",
    "no-new-func": "error",
    // Blocking browser dialogs (alert/confirm/prompt) are wrong here — the app
    // uses the Tauri dialog plugin's async `confirm`, never `window.confirm`.
    "no-alert": "error",

    // --- eqeqeq: keep it, but allow the deliberate `== null` nullish idiom ---
    // The store checks `x == null` / `x != null` on purpose to catch BOTH null
    // and undefined (values are `T | null | undefined` under
    // noUncheckedIndexedAccess). `null: "ignore"` keeps `===` enforced
    // everywhere else while permitting these documented nullish guards.
    "eqeqeq": ["error", "always", { "null": "ignore" }],

    // --- Deliberate off (false positive for the stack) ---
    // React 19 automatic JSX runtime (tsconfig `jsx: react-jsx`); the project
    // intentionally does not import React just to satisfy the classic runtime.
    "react/react-in-jsx-scope": "off",

    // --- Deliberate off (conflicts with a documented codebase convention) ---
    // This codebase documents heavily with same-line inline comments; the rule
    // fights that intentional style (and this very config relies on it).
    "no-inline-comments": "off",
    // Diff lines and hunks render from an immutable, append-only, never-reordered
    // list, so the array index IS the correct stable React key here.
    "react/no-array-index-key": "off",
    // The app manipulates the load-bearing `data-theme` attribute directly (see
    // applyThemeToDom): a MutationObserver watches `attributeFilter: ["data-theme"]`
    // and the system-reset path needs `removeAttribute`, which has no lossless
    // `dataset` equivalent. The attribute API is clearer and contract-exact here.
    "unicorn/prefer-dom-node-dataset": "off",
    // The store stages/unstages files with sequential `await`s ON PURPOSE (the
    // backend serialises index writes; sequencing preserves ordered error
    // capture). Parallelising would change behaviour.
    "no-await-in-loop": "off",
    // Terminal side-effect `.then()` handlers set React state and intentionally
    // return nothing; a synthetic return only adds noise.
    "promise/always-return": "off",

    // --- Deliberate off (pure size metrics; no correctness signal) ---
    // The zustand store factory closure and the larger React components are
    // cohesive by design; splitting them to satisfy a line-count metric would
    // harm readability, not help it.
    "max-lines-per-function": "off",
    "max-lines": "off",

    // --- Type-aware rules kept ON (the valuable core) ---
    // no-floating-promises, no-misused-promises, await-thenable,
    // no-for-in-array, no-unnecessary-type-assertion, no-unnecessary-condition,
    // restrict-plus-operands, restrict-template-expressions, unbound-method,
    // require-await, etc. all stay at error via the categories above. The store's
    // deliberate fire-and-forget promises already satisfy no-floating-promises
    // (every one uses `void`/`.catch`), so nothing is silenced there.

    // --- Type-aware rules deliberately OFF (typescript-eslint's own
    //     non-recommended / "onerous" strict tier; each would force massive
    //     churn or behaviour-risk for ~zero bug-catching value here) ---
    // Would require `readonly` on essentially every parameter (incl. React
    // props and store args). typescript-eslint documents it as impractical and
    // excludes it from every recommended preset.
    "typescript/prefer-readonly-parameter-types": "off",
    // The codebase deliberately treats empty-string and null identically as
    // "absent" (`if (errorMsg)`, `if (renamedFrom)`); explicit nullish+empty
    // guards everywhere would be pure verbosity with no behaviour change.
    "typescript/strict-boolean-expressions": "off",
    // Flags idiomatic inline handlers like `onClick={() => store.action()}`;
    // forcing a block body on every arrow handler is noise.
    "typescript/no-confusing-void-expression": "off",
    // False-positive on React `useEffect` callbacks, which legitimately return
    // either a cleanup function or nothing depending on the branch.
    "typescript/consistent-return": "off",
    // The few `as` casts are deliberate boundary narrowings at third-party
    // (shiki's over-narrow bundled-literal unions) and DOM/test-mock edges;
    // they are safe and intentional, not accidental widening.
    "typescript/no-unsafe-type-assertion": "off",

    // ============================================================================
    // Style tier promoted to "error" (zero-warnings policy triage)
    // ============================================================================
    // The whole `style` category is now "error". The entries below are the
    // per-rule triage of everything it surfaced. Each "off" fights an established
    // house convention and carries its own justification — there is NO blanket
    // category "off" anywhere. Rules not listed here stay at "error".

    // --- Configured to match house convention (rule stays ON) ---
    // House convention (typescript skill) is `type`, never `interface`; the rule
    // defaults to the opposite direction. There are zero `interface`
    // declarations, so this simply locks the convention in as enforced.
    "typescript/consistent-type-definitions": ["error", "type"],
    // Require braces when the body is on its own line, but allow the codebase's
    // deliberate, pervasive terse single-line guards (`if (x) return null;`).
    // The default "all" would add noise-only braces to every early-return guard.
    "curly": ["error", "multi-line"],

    // --- Deliberate off: mechanical ordering that destroys semantic grouping ---
    // Object keys are grouped semantically (domain fields, then flags, then
    // collections; store-slice and test-fixture groupings mirror their types),
    // not alphabetically. Alphabetizing scrambles meaning. oxfmt does not reorder
    // keys, so nothing else fights this.
    "sort-keys": "off",
    // Imports are grouped by origin/kind (external deps, then `import type`, then
    // local modules; dependency order such as react → react-dom → local), not
    // alphabetically. oxfmt intentionally leaves import order untouched, so this
    // rule would be the SOLE enforcer of an alphabetical order that destroys that
    // grouping — same rationale as sort-keys.
    "sort-imports": "off",

    // --- Deliberate off: fights the documented comment style ---
    // The codebase documents heavily with lowercase same-line/continuation
    // comments (see `no-inline-comments: off` above, and this very file). Forcing
    // a leading capital is pure noise and can corrupt code-in-comments, URLs, and
    // directive comments.
    "capitalized-comments": "off",

    // --- Deliberate off: `null` is part of the IPC contract ---
    // `null` is the wire shape of the Rust/serde IPC types (`DiffLine.oldLineNo:
    // number | null`, `RepoStatus`, `FileDiff.language`, …) and the store's
    // documented `== null` nullish idiom. Rewriting to `undefined` would diverge
    // from the backend contract and change round-trip serialization semantics.
    "unicorn/no-null": "off",

    // --- Deliberate off: PascalCase components, camelCase modules ---
    // Files are PascalCase for React components (`FileRow.tsx`) and camelCase for
    // modules/hooks (`useAppStore.ts`, `hunkPayload.ts`). unicorn defaults to
    // kebab-case; enforcing it would rename every file and fight React/TS norms.
    "unicorn/filename-case": "off",

    // --- Deliberate off: pure size/shape metrics (no correctness signal) ---
    // Consistent with the already-off max-lines / max-lines-per-function: these
    // count statements, params, and JSX depth, and would force splitting cohesive
    // functions and flattening readable JSX to satisfy an arbitrary threshold.
    "max-statements": "off",
    "max-params": "off",
    "react/jsx-max-depth": "off",

    // --- Deliberate off: UI/layout/test magic numbers ---
    // Layout sizes, virtualization thresholds, timeouts, and test fixtures use
    // inline numeric literals that read more clearly in place than hoisted to
    // named constants. No correctness signal.
    "no-magic-numbers": "off",
    // Short identifiers (`f`, `r`, `e`, `hl`, `mql`) are idiomatic in callbacks,
    // reducers, and tests; a 2-char minimum fights that for no readability gain.
    "id-length": "off",

    // --- Deliberate off: fights the intentional function-declaration mix ---
    // The codebase deliberately uses named `function` declarations for React
    // components and top-level helpers, and arrow consts for handlers and small
    // factories. `func-style` enforces exactly ONE form and cannot express that
    // split, so it fights the convention (typescript skill: named components).
    "func-style": "off",
    // Ternaries are the idiomatic conditional-render form in JSX and for small
    // value selections here; an outright ban forces verbose if/else with no gain.
    "no-ternary": "off",

    // --- Deliberate off: declare-then-assign is intentional ---
    // `let x;` then assignment inside a `try`, branch, or `switch` (and the
    // deferred-promise capture in the testkit) is deliberate; initializing at the
    // declaration would need `= undefined` (which unicorn/no-useless-undefined
    // then flags) or a semantic restructure.
    "init-declarations": "off",

    // --- Deliberate off: `window` guards detect the non-DOM environment ---
    // `typeof window === "undefined"` guards genuinely detect the test/non-DOM
    // environment before touching `matchMedia`/`addEventListener`. `globalThis`
    // is ALWAYS defined, so the rule's rewrite would neuter those guards — a
    // behavior change, not a cosmetic one.
    "unicorn/prefer-global-this": "off",

    // --- Deliberate off: fire-and-forget `.then` and deferred promises ---
    // The store/highlight layers use terminal `.then()` / `.then(ok, err)`
    // handlers on purpose (they set React state and return nothing — see
    // `promise/always-return: off` above), and the testkit builds a controllable
    // promise via `new Promise`. These three rules fight those deliberate
    // patterns; the valuable `no-floating-promises` (type-aware) still applies.
    "promise/prefer-await-to-then": "off",
    "promise/prefer-await-to-callbacks": "off",
    "promise/avoid-new": "off"
  },
  "overrides": [
    {
      // Test files exercise DOM/mocks in ways these rules mis-flag: explicit
      // `undefined` args/assertions are meaningful in tests, Testing Library
      // matchers use plain (non-`/u`) regexes, and local per-test helper closures
      // are fine. None of these are production-safety signals.
      "files": ["**/*.test.ts", "**/*.test.tsx", "src/test/**"],
      "rules": {
        "unicorn/no-useless-undefined": "off",
        "require-unicode-regexp": "off",
        "unicorn/consistent-function-scoping": "off",
        // jsdom stubs (setup.ts) cast partial mocks to their DOM interfaces; the
        // type engine flags these as redundant, but they document intent and are
        // test-only. No production code triggers this rule.
        "typescript/no-unnecessary-type-assertion": "off",
        // `vi.mock(...)` factories are hoisted above all imports, so they cannot
        // reference a top-level const; the `(await import("../test/factories"))
        // .mockGitApi()` inline member access on the await IS the required idiom.
        "unicorn/no-await-expression-member": "off",
        // Test render helpers spread a prepared `handlers`/props bag onto the
        // component under test — a standard testing-library ergonomic, not a
        // production prop-drilling smell.
        "react/jsx-props-no-spreading": "off"
      }
    },
    {
      // vite.config.ts reads an untyped Node global (`process.env.TAURI_DEV_HOST`,
      // guarded by an existing @ts-expect-error) and uses `||` on it to treat an
      // empty value as "no host". These type-aware rules fire only because that
      // build-tool global is `any`; the app source is fully covered.
      "files": ["vite.config.ts"],
      "rules": {
        "typescript/no-unsafe-assignment": "off",
        "typescript/no-unsafe-member-access": "off",
        "typescript/prefer-nullish-coalescing": "off"
      }
    }
  ],
  "ignorePatterns": ["dist", "src-tauri/target", "node_modules", "scripts"]
}
