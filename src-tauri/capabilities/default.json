{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window and per-repo windows",
  "windows": ["main", "repo-*"],
  "permissions": [
    "core:default",
    "core:window:allow-set-theme",
    "core:window:allow-set-title",
    "opener:default",
    "dialog:default",
    "store:default"
  ]
}
